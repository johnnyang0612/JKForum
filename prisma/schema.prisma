// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 列舉型別 (Enums)
// ============================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  MUTED
  BANNED
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
  LOCKED
}

enum PostVisibility {
  PUBLIC
  REPLY_TO_VIEW
  PAID
  VIP_ONLY
  PRIVATE
}

enum ReplyStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum ReportType {
  PORNOGRAPHY
  VIOLENCE
  SPAM
  HARASSMENT
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  POST
  REPLY
  USER
}

enum NotificationType {
  REPLY
  LIKE
  FOLLOW
  MENTION
  SYSTEM
  REPORT_RESULT
  LEVEL_UP
  ACHIEVEMENT
}

enum PointType {
  REPUTATION
  COINS
  PLATINUM
  HEARTS
  GEMS
  GIVEN
  ENERGY
  INVITES
}

enum PointChangeReason {
  POST_CREATED
  POST_LIKED
  REPLY_CREATED
  REPLY_LIKED
  DAILY_CHECKIN
  CHECKIN_STREAK
  ACHIEVEMENT_UNLOCK
  ADMIN_ADJUST
  VIP_BONUS
  PENALTY
}

enum AdminActionType {
  USER_BAN
  USER_UNBAN
  USER_MUTE
  USER_UNMUTE
  POST_DELETE
  POST_HIDE
  POST_PIN
  POST_UNPIN
  POST_FEATURE
  POST_LOCK
  POST_MOVE
  REPLY_DELETE
  FORUM_CREATE
  FORUM_EDIT
  FORUM_DELETE
  REPORT_RESOLVE
  REPORT_DISMISS
  POINTS_ADJUST
  LEVEL_ADJUST
  SETTINGS_CHANGE
}

// ============================================================
// NextAuth.js 必需模型
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// 用戶系統
// ============================================================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  emailVerified  DateTime?
  hashedPassword String?
  username       String     @unique @db.VarChar(30)
  displayName    String     @db.VarChar(50)
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?
  lastLoginIp    String?    @db.VarChar(45)

  // MFA / 雙因素認證
  twoFactorSecret      String? @map("two_factor_secret")
  twoFactorEnabled     Boolean @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes String? @map("two_factor_backup_codes")

  // 年齡驗證
  birthdate            DateTime? @db.Date
  ageConfirmedAt       DateTime? @map("age_confirmed_at")

  // 關聯
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  points        UserPoints?

  // 內容
  posts         Post[]
  replies       Reply[]

  // 互動
  likes         Like[]
  favorites     Favorite[]
  reports       Report[]        @relation("reporter")

  // 通知
  notifications Notification[]  @relation("recipient")

  // 用戶關係
  following     UserFollow[]    @relation("follower")
  followers     UserFollow[]    @relation("following")
  blocking      UserBlock[]     @relation("blocker")
  blockedBy     UserBlock[]     @relation("blocked")

  // 簽到
  checkins      Checkin[]

  // VIP / 商城 / 任務
  vipSubscriptions VipSubscription[]
  items            UserItem[]
  taskProgress     UserTaskProgress[]

  // 版主
  moderating    ForumModerator[]

  // 管理日誌
  adminLogs     AdminLog[]

  // 私訊系統
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[] @relation("messageSender")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  avatarUrl   String?  @db.Text
  signature   String?  @db.VarChar(200)
  bio         String?  @db.VarChar(500)
  website     String?  @db.VarChar(255)
  location    String?  @db.VarChar(100)
  birthday    DateTime?
  gender      String?  @db.VarChar(10)
  isPublic    Boolean  @default(true)

  // 統計快取
  postCount      Int @default(0)
  replyCount     Int @default(0)
  likeCount      Int @default(0)
  followerCount  Int @default(0)
  followingCount Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PointRule {
  id               String   @id @default(cuid())
  action           String   @unique
  scope            String   @default("global")
  cycle            String?
  maxTimes         Int?     @map("max_times")
  rewardReputation Int      @default(0) @map("reward_reputation")
  rewardCoins      Int      @default(0) @map("reward_coins")
  rewardHearts     Int      @default(0) @map("reward_hearts")
  rewardGiven      Int      @default(0) @map("reward_given")
  rewardEnergy     Int      @default(0) @map("reward_energy")
  rewardGems       Int      @default(0) @map("reward_gems")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("point_rules")
}

model Tip {
  id        String   @id @default(cuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  postId    String?  @map("post_id")
  replyId   String?  @map("reply_id")
  amount    Int
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  post Post? @relation("PostTips", fields: [postId], references: [id], onDelete: SetNull)

  @@index([toId, createdAt])
  @@index([fromId, createdAt])
  @@index([postId])
  @@map("tips")
}

model Medal {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  iconEmoji   String? @map("icon_emoji")
  iconUrl     String? @map("icon_url")
  tier        String  @default("bronze")
  category    String  @default("activity")
  ruleType    String  @map("rule_type")
  ruleValue   Int?    @map("rule_value")
  ruleMetric  String? @map("rule_metric")
  isAuto      Boolean @default(true) @map("is_auto")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  holders UserMedal[]

  @@index([isActive, category, sortOrder])
  @@map("medals")
}

model UserMedal {
  userId     String   @map("user_id")
  medalId    String   @map("medal_id")
  awardedAt  DateTime @default(now()) @map("awarded_at")
  awardedBy  String?  @map("awarded_by")
  note       String?

  medal Medal @relation(fields: [medalId], references: [id], onDelete: Cascade)

  @@id([userId, medalId])
  @@index([userId, awardedAt])
  @@index([medalId, awardedAt])
  @@map("user_medals")
}

model PointLedger {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String
  delta       Json
  relatedId   String?  @map("related_id")
  relatedType String?  @map("related_type")
  forumId     String?  @map("forum_id")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, action, createdAt])
  @@index([userId, createdAt])
  @@map("point_ledger")
}

model UserPoints {
  id         String @id @default(cuid())
  userId     String @unique

  reputation Int @default(0)
  coins      Int @default(0)
  platinum   Int @default(0)
  hearts     Int @default(0)
  gems       Int @default(0)
  given      Int @default(0)
  energy     Int @default(100)
  invites    Int @default(0)

  totalPoints Int @default(0)
  level       Int @default(16)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model PointHistory {
  id        String            @id @default(cuid())
  userId    String
  type      PointType
  amount    Int
  reason    PointChangeReason
  detail    String?           @db.VarChar(200)
  relatedId String?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("point_histories")
}

// ============================================================
// 用戶關係
// ============================================================

model Friendship {
  id          String       @id @default(cuid())
  requesterId String       @map("requester_id")
  addresseeId String       @map("addressee_id")
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  acceptedAt  DateTime?    @map("accepted_at")

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model ProfileVisit {
  id        String   @id @default(cuid())
  visitorId String   @map("visitor_id")
  profileId String   @map("profile_id")
  visitedAt DateTime @default(now()) @map("visited_at")

  @@unique([visitorId, profileId])
  @@index([profileId, visitedAt])
  @@map("profile_visits")
}

model ForumFollow {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  forumId   String   @map("forum_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, forumId])
  @@index([userId, createdAt])
  @@index([forumId])
  @@map("forum_follows")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ============================================================
// 看板系統（三層架構）
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  iconUrl     String?  @db.Text
  iconEmoji   String?  @map("icon_emoji")
  rating      ContentRating @default(G)
  isEnabled   Boolean  @default(true) @map("is_enabled")
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forums Forum[]

  @@index([slug])
  @@index([sortOrder])
  @@map("categories")
}

enum ContentRating {
  G
  PG13
  R18
}

model LeaderboardSnapshot {
  id           String   @id @default(cuid())
  type         String   @unique
  rows         Json
  refreshedAt  DateTime @default(now()) @map("refreshed_at")

  @@map("leaderboard_snapshots")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model Forum {
  id             String   @id @default(cuid())
  categoryId     String
  name           String   @db.VarChar(100)
  slug           String   @unique @db.VarChar(100)
  description    String?  @db.Text
  iconUrl        String?  @db.Text
  bannerUrl      String?  @db.Text
  rules          String?  @db.Text
  sortOrder      Int      @default(0)
  isVisible      Boolean  @default(true)
  isLocked       Boolean  @default(false)
  minLevelToPost Int      @default(16)
  minLevelToView Int      @default(16)
  rating          ContentRating @default(G)
  ageGateEnabled  Boolean @default(false) @map("age_gate_enabled")

  // 統計快取
  postCount      Int      @default(0)
  todayPostCount Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subforums  Subforum[]
  posts      Post[]
  moderators ForumModerator[]

  @@index([categoryId])
  @@index([slug])
  @@index([sortOrder])
  @@map("forums")
}

model Subforum {
  id          String   @id @default(cuid())
  forumId     String
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forum Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([forumId, slug])
  @@index([forumId])
  @@map("subforums")
}

model ForumModerator {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  createdAt DateTime @default(now())

  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
  @@map("forum_moderators")
}

// ============================================================
// 文章與回覆系統
// ============================================================

model Post {
  id             String         @id @default(cuid())
  authorId       String
  forumId        String
  subforumId     String?
  title          String         @db.VarChar(200)
  content        String         @db.Text
  excerpt        String?        @db.VarChar(300)
  slug           String         @unique @db.VarChar(250)
  status         PostStatus     @default(PUBLISHED)
  visibility     PostVisibility @default(PUBLIC)
  paidCoins      Int            @default(0)
  minReadPermission Int         @default(0)   @map("min_read_permission")
  rating            ContentRating @default(G)

  // 置頂與精華
  isPinned       Boolean        @default(false)
  pinnedAt       DateTime?
  isFeatured     Boolean        @default(false)
  featuredAt     DateTime?
  isHighlighted  Boolean        @default(false)
  highlightColor String?        @db.VarChar(7)

  // 統計快取
  viewCount      Int            @default(0)
  likeCount      Int            @default(0)
  dislikeCount   Int            @default(0)
  replyCount     Int            @default(0)
  favoriteCount  Int            @default(0)

  // 最後活動
  lastReplyAt    DateTime?
  lastReplyById  String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // 關聯
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum       Forum           @relation(fields: [forumId], references: [id], onDelete: Cascade)
  subforum    Subforum?       @relation(fields: [subforumId], references: [id], onDelete: SetNull)
  replies     Reply[]
  attachments PostAttachment[]
  likes       Like[]
  favorites   Favorite[]
  reports     Report[]
  tags        PostTag[]
  unlocks     PostUnlock[]
  tips        Tip[]        @relation("PostTips")

  @@index([authorId])
  @@index([forumId, status, createdAt])
  @@index([forumId, isPinned, lastReplyAt])
  @@index([forumId, subforumId, status])
  @@index([status, createdAt])
  @@index([slug])
  @@index([likeCount])
  @@index([viewCount])
  @@map("posts")
}

model Reply {
  id           String      @id @default(cuid())
  postId       String
  authorId     String
  parentId     String?
  content      String      @db.Text
  status       ReplyStatus @default(PUBLISHED)
  floor        Int

  // 統計
  likeCount    Int         @default(0)
  dislikeCount Int         @default(0)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // 關聯
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Reply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children Reply[] @relation("ReplyToReply")
  likes    Like[]

  @@index([postId, floor])
  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("replies")
}

model PostAttachment {
  id         String   @id @default(cuid())
  postId     String
  fileName   String   @db.VarChar(255)
  fileUrl    String   @db.Text
  fileSize   Int
  mimeType   String   @db.VarChar(100)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

// ============================================================
// 互動系統
// ============================================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  replyId   String?
  isLike    Boolean  @default(true)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply Reply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([postId])
  @@index([replyId])
  @@map("likes")
}

model PostUnlock {
  userId     String   @map("user_id")
  postId     String   @map("post_id")
  paidCoins  Int      @default(0) @map("paid_coins")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("post_unlocks")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@map("favorites")
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  type        ReportType
  reason      String           @db.Text
  evidence    String?          @db.Text
  status      ReportStatus     @default(PENDING)
  resolution  String?          @db.Text
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reporter User  @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@map("reports")
}

// ============================================================
// 標籤系統
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String?  @db.VarChar(7)
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  posts PostTag[]

  @@index([slug])
  @@index([postCount])
  @@map("tags")
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String           @db.VarChar(200)
  content     String?          @db.VarChar(500)
  linkUrl     String?          @db.Text
  isRead      Boolean          @default(false)
  senderId    String?
  relatedId   String?
  createdAt   DateTime         @default(now())

  recipient User @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ============================================================
// 簽到系統
// ============================================================

model Checkin {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  streak      Int      @default(1)
  coinsEarned Int      @default(30)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("checkins")
}

// ============================================================
// 管理日誌
// ============================================================

model AdminLog {
  id         String          @id @default(cuid())
  adminId    String
  action     AdminActionType
  targetType String          @db.VarChar(50)
  targetId   String
  detail     String?         @db.Text
  ipAddress  String?         @db.VarChar(45)
  createdAt  DateTime        @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@map("admin_logs")
}

// ============================================================
// 私訊系統
// ============================================================

model Conversation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ============================================================
// VIP 訂閱系統
// ============================================================

model VipSubscription {
  id        String    @id @default(cuid())
  userId    String
  plan      VipPlan
  status    VipStatus @default(ACTIVE)
  startDate DateTime  @default(now())
  endDate   DateTime
  autoRenew Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([endDate])
  @@map("vip_subscriptions")
}

enum VipPlan {
  MONTHLY    // NT$99/月
  QUARTERLY  // NT$249/3月
  YEARLY     // NT$799/年
}

enum VipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// ============================================================
// 商城系統
// ============================================================

model ShopItem {
  id          String       @id @default(cuid())
  name        String       @db.VarChar(100)
  description String?      @db.Text
  type        ShopItemType
  price       Int                    // 價格（金幣或白金幣）
  currency    PointType              // COINS or PLATINUM
  iconUrl     String?      @db.Text
  effect      String?      @db.VarChar(200)  // 效果描述
  duration    Int?                   // 時效（小時），null=永久
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  purchases UserItem[]

  @@index([type, isActive])
  @@map("shop_items")
}

model UserItem {
  id         String    @id @default(cuid())
  userId     String
  itemId     String
  quantity   Int       @default(1)
  usedAt     DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
  @@map("user_items")
}

enum ShopItemType {
  BOOST      // 置頂卡、高亮卡
  BADGE      // 勳章
  FEATURE    // 功能解鎖
}

// ============================================================
// 任務與成就系統
// ============================================================

model Task {
  id               String   @id @default(cuid())
  name             String   @db.VarChar(100)
  description      String   @db.Text
  type             TaskType
  target           Int               // 目標數量
  rewardCoins      Int      @default(0)
  rewardReputation Int      @default(0)
  rewardGems       Int      @default(0)  // 寶石（稀有）
  badgeId          String?            // 完成後獲得勳章
  iconUrl          String?  @db.Text
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  progress UserTaskProgress[]

  @@index([type, isActive])
  @@map("tasks")
}

model UserTaskProgress {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId, completed])
  @@map("user_task_progress")
}

enum TaskType {
  NEWBIE      // 新手任務
  DAILY       // 日常任務
  ACHIEVEMENT // 成就任務
}

// ============================================================
// 廣告系統
// ============================================================

model Advertisement {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(200)
  imageUrl    String     @db.Text
  linkUrl     String     @db.Text
  position    AdPosition
  width       Int?
  height      Int?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  priority    Int        @default(0)     // 數字越大優先顯示
  targetForums String?   @db.Text        // JSON array of forum IDs, null = 全部看板

  // 統計
  impressions Int        @default(0)
  clicks      Int        @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([position, isActive, startDate, endDate])
  @@index([isActive])
  @@map("advertisements")
}

enum AdPosition {
  HOME_BANNER       // 首頁橫幅
  SIDEBAR           // 側邊欄
  POST_INLINE       // 文章內穿插
  OVERLAY           // 蓋版廣告
  POPUP             // 彈出式
}
