// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 列舉型別 (Enums)
// ============================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

// JKF 18 層會員組 — readPower 為閱讀權限數值
enum UserGroup {
  PEASANT // 平民       readPower 10
  SQUIRE // 鄉紳       readPower 20
  KNIGHT // 騎士       readPower 30
  BARON // 男爵       readPower 40
  VISCOUNT // 子爵       readPower 50
  EARL // 伯爵       readPower 60
  MARQUIS // 侯爵       readPower 70
  DUKE // 公爵       readPower 80
  PRINCE // 親王       readPower 90
  KING // 國王       readPower 100
  EMPEROR // 皇帝       readPower 110
  IMMORTAL // 仙人       readPower 120
  SAGE // 聖人       readPower 130
  GOD // 神祇       readPower 140
  VIP // VIP        readPower 150
  EDITOR // 駐站編輯   readPower 160
  MODERATOR_GRP // 版主組     readPower 180
  ADMIN_GRP // 站長組     readPower 200
}

enum UserStatus {
  ACTIVE
  MUTED
  BANNED
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
  LOCKED
}

enum PostVisibility {
  PUBLIC
  REPLY_TO_VIEW
  PAID
  VIP_ONLY
  PRIVATE
}

enum ReplyStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum ReportType {
  PORNOGRAPHY
  VIOLENCE
  SPAM
  HARASSMENT
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  POST
  REPLY
  USER
}

enum NotificationType {
  REPLY
  LIKE
  FOLLOW
  MENTION
  SYSTEM
  REPORT_RESULT
  LEVEL_UP
  ACHIEVEMENT
}

enum PointType {
  REPUTATION
  COINS
  PLATINUM
  HEARTS
  GEMS
  GIVEN
  ENERGY
  INVITES
}

enum PointChangeReason {
  POST_CREATED
  POST_LIKED
  REPLY_CREATED
  REPLY_LIKED
  DAILY_CHECKIN
  CHECKIN_STREAK
  ACHIEVEMENT_UNLOCK
  ADMIN_ADJUST
  VIP_BONUS
  PENALTY
}

enum AdminActionType {
  USER_BAN
  USER_UNBAN
  USER_MUTE
  USER_UNMUTE
  POST_DELETE
  POST_HIDE
  POST_PIN
  POST_UNPIN
  POST_FEATURE
  POST_LOCK
  POST_MOVE
  REPLY_DELETE
  FORUM_CREATE
  FORUM_EDIT
  FORUM_DELETE
  REPORT_RESOLVE
  REPORT_DISMISS
  POINTS_ADJUST
  LEVEL_ADJUST
  SETTINGS_CHANGE
}

// ============================================================
// NextAuth.js 必需模型
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// 用戶系統
// ============================================================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  emailVerified  DateTime?
  hashedPassword String?
  username       String     @unique @db.VarChar(30)
  displayName    String     @db.VarChar(50)
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?
  lastLoginIp    String?    @db.VarChar(45)

  // MFA / 雙因素認證
  twoFactorSecret      String? @map("two_factor_secret")
  twoFactorEnabled     Boolean @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes String? @map("two_factor_backup_codes")

  // 年齡驗證
  birthdate      DateTime? @db.Date
  ageConfirmedAt DateTime? @map("age_confirmed_at")

  // JKF 會員組（18 層）+ 閱讀權限
  userGroup      UserGroup @default(PEASANT) @map("user_group")
  readPermission Int       @default(10) @map("read_permission")

  // 個人空間擴充
  coverPhotoUrl String? @map("cover_photo_url") @db.Text
  registerIp    String? @map("register_ip") @db.VarChar(45)

  // 代表勳章（profile 頭像旁顯示）+ 頭框
  representativeMedalSlug String? @map("representative_medal_slug") @db.VarChar(60)
  avatarFrame             String? @map("avatar_frame") @db.VarChar(40) // gold/silver/bronze/purple/green

  // SMS 驗證（KYC Lite — Email 已有 emailVerified 欄位）
  phoneNumber  String?  @map("phone_number") @db.VarChar(20)
  phoneCountry String?  @map("phone_country") @db.VarChar(5) // +886
  smsVerified  DateTime? @map("sms_verified")
  smsCode      String?  @map("sms_code") @db.VarChar(10)
  smsCodeSentAt DateTime? @map("sms_code_sent_at")

  // PRD-0503：業者角色
  userType             UserType @default(MEMBER) @map("user_type")
  merchantName         String?  @map("merchant_name") @db.VarChar(60)
  merchantBio          String?  @map("merchant_bio") @db.Text
  merchantVerified     Boolean  @default(false) @map("merchant_verified")
  merchantVerifiedDocs Json     @default("[]") @map("merchant_verified_docs")

  // 關聯
  accounts Account[]
  sessions Session[]
  profile  UserProfile?
  points   UserPoints?

  // 內容
  posts   Post[]
  replies Reply[]

  // 互動
  likes     Like[]
  favorites Favorite[]
  reports   Report[]   @relation("reporter")

  // 通知
  notifications Notification[] @relation("recipient")

  // 用戶關係
  following UserFollow[] @relation("follower")
  followers UserFollow[] @relation("following")
  blocking  UserBlock[]  @relation("blocker")
  blockedBy UserBlock[]  @relation("blocked")

  // 簽到
  checkins Checkin[]

  // VIP / 商城 / 任務
  vipSubscriptions VipSubscription[]
  items            UserItem[]
  taskProgress     UserTaskProgress[]

  // 版主
  moderating ForumModerator[]

  // 管理日誌
  adminLogs AdminLog[]

  // 私訊系統
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                 @relation("messageSender")

  // 遊戲中心
  gameItems        UserGameItem[]
  mineSessions     MineSession[]
  exploreSessions  ExploreSession[]
  treasureSessions TreasureSession[]

  // 個人日誌 / 文章評分 / 投票
  blogs        Blog[]
  blogComments BlogComment[]
  postRatings  PostRating[]
  pollVotes    PollVote[]

  // 即時留言版
  chatMessages ChatMessage[] @relation("chatSender")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([userGroup])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  avatarUrl String?   @db.Text
  signature String?   @db.VarChar(200)
  bio       String?   @db.VarChar(500)
  website   String?   @db.VarChar(255)
  location  String?   @db.VarChar(100)
  birthday  DateTime?
  gender    String?   @db.VarChar(10)
  isPublic  Boolean   @default(true)

  // 統計快取
  postCount      Int @default(0)
  replyCount     Int @default(0)
  likeCount      Int @default(0)
  followerCount  Int @default(0)
  followingCount Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PointRule {
  id               String   @id @default(cuid())
  action           String   @unique
  scope            String   @default("global")
  cycle            String?
  maxTimes         Int?     @map("max_times")
  rewardReputation Int      @default(0) @map("reward_reputation")
  rewardCoins      Int      @default(0) @map("reward_coins")
  rewardHearts     Int      @default(0) @map("reward_hearts")
  rewardGiven      Int      @default(0) @map("reward_given")
  rewardEnergy     Int      @default(0) @map("reward_energy")
  rewardGems       Int      @default(0) @map("reward_gems")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("point_rules")
}

model Tip {
  id        String   @id @default(cuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  postId    String?  @map("post_id")
  replyId   String?  @map("reply_id")
  amount    Int
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  post Post? @relation("PostTips", fields: [postId], references: [id], onDelete: SetNull)

  @@index([toId, createdAt])
  @@index([fromId, createdAt])
  @@index([postId])
  @@map("tips")
}

model Medal {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  iconEmoji   String?  @map("icon_emoji")
  iconUrl     String?  @map("icon_url")
  tier        String   @default("bronze")
  category    String   @default("activity")
  ruleType    String   @map("rule_type")
  ruleValue   Int?     @map("rule_value")
  ruleMetric  String?  @map("rule_metric")
  isAuto      Boolean  @default(true) @map("is_auto")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  holders UserMedal[]

  @@index([isActive, category, sortOrder])
  @@map("medals")
}

model UserMedal {
  userId    String   @map("user_id")
  medalId   String   @map("medal_id")
  awardedAt DateTime @default(now()) @map("awarded_at")
  awardedBy String?  @map("awarded_by")
  note      String?

  medal Medal @relation(fields: [medalId], references: [id], onDelete: Cascade)

  @@id([userId, medalId])
  @@index([userId, awardedAt])
  @@index([medalId, awardedAt])
  @@map("user_medals")
}

model PointLedger {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String
  delta       Json
  relatedId   String?  @map("related_id")
  relatedType String?  @map("related_type")
  forumId     String?  @map("forum_id")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, action, createdAt])
  @@index([userId, createdAt])
  @@map("point_ledger")
}

model UserPoints {
  id     String @id @default(cuid())
  userId String @unique

  reputation Int @default(0)
  coins      Int @default(0)
  platinum   Int @default(0)
  hearts     Int @default(0)
  gems       Int @default(0)
  given      Int @default(0)
  energy     Int @default(100)
  invites    Int @default(0)

  totalPoints Int @default(0)
  level       Int @default(16)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model PointHistory {
  id        String            @id @default(cuid())
  userId    String
  type      PointType
  amount    Int
  reason    PointChangeReason
  detail    String?           @db.VarChar(200)
  relatedId String?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("point_histories")
}

// ============================================================
// 用戶關係
// ============================================================

model Friendship {
  id          String       @id @default(cuid())
  requesterId String       @map("requester_id")
  addresseeId String       @map("addressee_id")
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  acceptedAt  DateTime?    @map("accepted_at")

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model ProfileVisit {
  id        String   @id @default(cuid())
  visitorId String   @map("visitor_id")
  profileId String   @map("profile_id")
  visitedAt DateTime @default(now()) @map("visited_at")

  @@unique([visitorId, profileId])
  @@index([profileId, visitedAt])
  @@map("profile_visits")
}

model ForumFollow {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  forumId   String   @map("forum_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, forumId])
  @@index([userId, createdAt])
  @@index([forumId])
  @@map("forum_follows")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ============================================================
// 看板系統（三層架構）
// ============================================================

model Category {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(100)
  slug        String        @unique @db.VarChar(100)
  description String?       @db.Text
  iconUrl     String?       @db.Text
  iconEmoji   String?       @map("icon_emoji")
  rating      ContentRating @default(G)
  isEnabled   Boolean       @default(true) @map("is_enabled")
  sortOrder   Int           @default(0)
  isVisible   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  forums Forum[]

  @@index([slug])
  @@index([sortOrder])
  @@map("categories")
}

enum ContentRating {
  G
  PG13
  R18
}

model LeaderboardSnapshot {
  id          String   @id @default(cuid())
  type        String   @unique
  rows        Json
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  @@map("leaderboard_snapshots")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model Forum {
  id             String        @id @default(cuid())
  categoryId     String
  name           String        @db.VarChar(100)
  slug           String        @unique @db.VarChar(100)
  description    String?       @db.Text
  iconUrl        String?       @db.Text
  bannerUrl      String?       @db.Text
  rules          String?       @db.Text
  sortOrder      Int           @default(0)
  isVisible      Boolean       @default(true)
  isLocked       Boolean       @default(false)
  minLevelToPost Int           @default(16)
  minLevelToView Int           @default(16)
  rating         ContentRating @default(G)
  ageGateEnabled Boolean       @default(false) @map("age_gate_enabled")

  // 統計快取
  postCount      Int @default(0)
  todayPostCount Int @default(0)

  // PRD-0503：付費刊登 / 業者廣告
  allowPaidListing    Boolean @default(false) @map("allow_paid_listing")
  defaultAdTier       String? @map("default_ad_tier")          // FREE / T500 / T1000 / T2000 / T3000
  themeCategoriesJson Json    @default("[]") @map("theme_categories_json") // 該版區可用的主題（如 室內/制服...）
  forceThemeCategory  Boolean @default(false) @map("force_theme_category") // 是否強制要選

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subforums  Subforum[]
  posts      Post[]
  moderators ForumModerator[]

  @@index([categoryId])
  @@index([slug])
  @@index([sortOrder])
  @@map("forums")
}

model Subforum {
  id          String   @id @default(cuid())
  forumId     String
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forum Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([forumId, slug])
  @@index([forumId])
  @@map("subforums")
}

model ForumModerator {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  createdAt DateTime @default(now())

  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
  @@map("forum_moderators")
}

// ============================================================
// 文章與回覆系統
// ============================================================

model Post {
  id                String         @id @default(cuid())
  authorId          String
  forumId           String
  subforumId        String?
  title             String         @db.VarChar(200)
  content           String         @db.Text
  excerpt           String?        @db.VarChar(300)
  slug              String         @unique @db.VarChar(250)
  status            PostStatus     @default(PUBLISHED)
  visibility        PostVisibility @default(PUBLIC)
  paidCoins         Int            @default(0)
  minReadPermission Int            @default(0) @map("min_read_permission")
  rating            ContentRating  @default(G)

  // 置頂與精華
  isPinned       Boolean   @default(false)
  pinnedAt       DateTime?
  isFeatured     Boolean   @default(false)
  featuredAt     DateTime?
  isHighlighted  Boolean   @default(false)
  highlightColor String?   @db.VarChar(7)

  // 統計快取
  viewCount     Int @default(0)
  likeCount     Int @default(0)
  dislikeCount  Int @default(0)
  replyCount    Int @default(0)
  favoriteCount Int @default(0)

  // 最後活動
  lastReplyAt   DateTime?
  lastReplyById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 進階能力
  scheduledAt          DateTime? @map("scheduled_at") // 排程發表
  allowAuthorOnlyReply Boolean   @default(false) @map("allow_author_only_reply") // 僅作者可見留言
  ratingAvg            Float     @default(0) @map("rating_avg")
  ratingCount          Int       @default(0) @map("rating_count")

  // 關聯
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum       Forum            @relation(fields: [forumId], references: [id], onDelete: Cascade)
  subforum    Subforum?        @relation(fields: [subforumId], references: [id], onDelete: SetNull)
  replies     Reply[]
  attachments PostAttachment[]
  likes       Like[]
  favorites   Favorite[]
  reports     Report[]
  tags        PostTag[]
  unlocks     PostUnlock[]
  tips        Tip[]            @relation("PostTips")
  ratings     PostRating[]
  poll        Poll?

  @@index([authorId])
  @@index([forumId, status, createdAt])
  @@index([forumId, isPinned, lastReplyAt])
  @@index([forumId, subforumId, status])
  @@index([status, createdAt])
  @@index([status, scheduledAt])
  @@index([slug])
  @@index([likeCount])
  @@index([viewCount])
  @@map("posts")
}

model Reply {
  id       String      @id @default(cuid())
  postId   String
  authorId String
  parentId String?
  content  String      @db.Text
  status   ReplyStatus @default(PUBLISHED)
  floor    Int

  // 統計
  likeCount    Int @default(0)
  dislikeCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 關聯
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Reply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children Reply[] @relation("ReplyToReply")
  likes    Like[]

  @@index([postId, floor])
  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("replies")
}

model PostAttachment {
  id        String   @id @default(cuid())
  postId    String
  fileName  String   @db.VarChar(255)
  fileUrl   String   @db.Text
  fileSize  Int
  mimeType  String   @db.VarChar(100)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

// ============================================================
// 互動系統
// ============================================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  replyId   String?
  isLike    Boolean  @default(true)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply Reply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([postId])
  @@index([replyId])
  @@map("likes")
}

model PostUnlock {
  userId     String   @map("user_id")
  postId     String   @map("post_id")
  paidCoins  Int      @default(0) @map("paid_coins")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("post_unlocks")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@map("favorites")
}

model Report {
  id         String           @id @default(cuid())
  reporterId String
  targetType ReportTargetType
  targetId   String
  type       ReportType
  reason     String           @db.Text
  evidence   String?          @db.Text
  status     ReportStatus     @default(PENDING)
  resolution String?          @db.Text
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  reporter User  @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@map("reports")
}

// ============================================================
// 標籤系統
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String?  @db.VarChar(7)
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  posts PostTag[]

  @@index([slug])
  @@index([postCount])
  @@map("tags")
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String           @db.VarChar(200)
  content     String?          @db.VarChar(500)
  linkUrl     String?          @db.Text
  isRead      Boolean          @default(false)
  senderId    String?
  relatedId   String?
  createdAt   DateTime         @default(now())

  recipient User @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ============================================================
// 簽到系統
// ============================================================

model Checkin {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  streak      Int      @default(1)
  coinsEarned Int      @default(30)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("checkins")
}

// ============================================================
// 管理日誌
// ============================================================

model AdminLog {
  id         String          @id @default(cuid())
  adminId    String
  action     AdminActionType
  targetType String          @db.VarChar(50)
  targetId   String
  detail     String?         @db.Text
  ipAddress  String?         @db.VarChar(45)
  createdAt  DateTime        @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@map("admin_logs")
}

// ============================================================
// 私訊系統
// ============================================================

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ============================================================
// VIP 訂閱系統
// ============================================================

model VipSubscription {
  id        String    @id @default(cuid())
  userId    String
  plan      VipPlan
  status    VipStatus @default(ACTIVE)
  startDate DateTime  @default(now())
  endDate   DateTime
  autoRenew Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([endDate])
  @@map("vip_subscriptions")
}

enum VipPlan {
  MONTHLY // NT$99/月
  QUARTERLY // NT$249/3月
  YEARLY // NT$799/年
}

enum VipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// ============================================================
// 商城系統
// ============================================================

model ShopItem {
  id          String       @id @default(cuid())
  name        String       @db.VarChar(100)
  description String?      @db.Text
  type        ShopItemType
  price       Int // 價格（金幣或白金幣）
  currency    PointType // COINS or PLATINUM
  iconUrl     String?      @db.Text
  effect      String?      @db.VarChar(200) // 效果描述
  duration    Int? // 時效（小時），null=永久
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  purchases UserItem[]

  @@index([type, isActive])
  @@map("shop_items")
}

model UserItem {
  id        String    @id @default(cuid())
  userId    String
  itemId    String
  quantity  Int       @default(1)
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
  @@map("user_items")
}

enum ShopItemType {
  BOOST // 置頂卡、高亮卡
  BADGE // 勳章
  FEATURE // 功能解鎖
}

// ============================================================
// 任務與成就系統
// ============================================================

model Task {
  id               String   @id @default(cuid())
  name             String   @db.VarChar(100)
  description      String   @db.Text
  type             TaskType
  target           Int // 目標數量
  rewardCoins      Int      @default(0)
  rewardReputation Int      @default(0)
  rewardGems       Int      @default(0) // 寶石（稀有）
  badgeId          String? // 完成後獲得勳章
  iconUrl          String?  @db.Text
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  progress UserTaskProgress[]

  @@index([type, isActive])
  @@map("tasks")
}

model UserTaskProgress {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId, completed])
  @@map("user_task_progress")
}

enum TaskType {
  NEWBIE // 新手任務
  DAILY // 日常任務
  ACHIEVEMENT // 成就任務
}

// ============================================================
// 廣告系統
// ============================================================

model Advertisement {
  id           String     @id @default(cuid())
  title        String     @db.VarChar(200)
  imageUrl     String     @db.Text
  linkUrl      String     @db.Text
  position     AdPosition
  width        Int?
  height       Int?
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean    @default(true)
  priority     Int        @default(0) // 數字越大優先顯示
  targetForums String?    @db.Text // JSON array of forum IDs, null = 全部看板

  // 統計
  impressions Int @default(0)
  clicks      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position, isActive, startDate, endDate])
  @@index([isActive])
  @@map("advertisements")
}

enum AdPosition {
  HOME_BANNER // 首頁橫幅
  SIDEBAR // 側邊欄
  POST_INLINE // 文章內穿插
  OVERLAY // 蓋版廣告
  POPUP // 彈出式
}

// ============================================================
// PWA Push 訂閱
// ============================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  ua        String?  @db.VarChar(300)
  createdAt DateTime @default(now()) @map("created_at")
  lastUsed  DateTime @default(now()) @map("last_used")

  @@index([userId])
  @@map("push_subscriptions")
}

// ============================================================
// 遊戲中心 — 道具 / 挖礦 / 探索 / 寶箱
// ============================================================

enum GameItemCategory {
  TOOL // 工具（放大鏡、研磨鑽…）
  AURA // 靈氣（聖/暗/水/火/地/風）
  GEM // 寶石/原石
  WOOD // 木材
  CHARM // 幸運符咒
  MATERIAL // 合成材料
  POTION // 藥水
  TROPHY // 戰利品（角、皮、果實等）
  RARE // 稀有道具
}

enum GameItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model GameItem {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String           @db.VarChar(60)
  description String?          @db.Text
  category    GameItemCategory
  rarity      GameItemRarity   @default(COMMON)
  iconEmoji   String?          @map("icon_emoji")
  iconUrl     String?          @map("icon_url") @db.Text
  // 商店價格（null 表示不上架，只能挖/合成取得）
  priceCoins  Int?             @map("price_coins")
  priceHearts Int?             @map("price_hearts")
  priceGems   Int?             @map("price_gems")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")

  inventory     UserGameItem[]
  ingredientFor RecipeIngredient[]
  outputOf      ItemRecipe[]       @relation("RecipeOutput")
  mineDrops     MineDrop[]
  exploreDrops  ExploreDrop[]
  treasureDrops TreasureDrop[]

  @@index([category, isActive])
  @@map("game_items")
}

model UserGameItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  quantity  Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item GameItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@map("user_game_items")
}

model ItemRecipe {
  id          String   @id @default(cuid())
  outputId    String   @map("output_id")
  outputCount Int      @default(1) @map("output_count")
  costCoins   Int      @default(0) @map("cost_coins")
  costEnergy  Int      @default(0) @map("cost_energy")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  output      GameItem           @relation("RecipeOutput", fields: [outputId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("item_recipes")
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String @map("recipe_id")
  itemId   String @map("item_id")
  quantity Int    @default(1)

  recipe ItemRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   GameItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([recipeId, itemId])
  @@map("recipe_ingredients")
}

// 礦坑：消耗 energy → 隨機掉落 GameItem
enum MineLocation {
  DRAGON_LAIR // 巨龍巢穴 (10 energy)
  ELF_CANYON // 精靈峽谷 (5 energy)
  ABANDONED_MINE // 廢棄礦坑 (1 energy)
}

model MineDrop {
  id       String       @id @default(cuid())
  location MineLocation
  itemId   String       @map("item_id")
  weight   Int          @default(1) // 機率權重
  minQty   Int          @default(1) @map("min_qty")
  maxQty   Int          @default(1) @map("max_qty")

  item GameItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([location])
  @@map("mine_drops")
}

model MineSession {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  location   MineLocation
  energyUsed Int          @map("energy_used")
  rewards    Json // [{itemId, quantity}]
  createdAt  DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("mine_sessions")
}

// 地形探索：消耗 energy → 隨機掉落
enum ExploreLocation {
  FALLEN_SANCTUARY // 墮落聖地 (10)
  BURNING_LAND // 焚燒之地 (5)
  GIANT_FOREST // 巨木森林 (1)
}

model ExploreDrop {
  id       String          @id @default(cuid())
  location ExploreLocation
  itemId   String          @map("item_id")
  weight   Int             @default(1)
  minQty   Int             @default(1) @map("min_qty")
  maxQty   Int             @default(1) @map("max_qty")

  item GameItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([location])
  @@map("explore_drops")
}

model ExploreSession {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  location   ExploreLocation
  energyUsed Int             @map("energy_used")
  rewards    Json
  createdAt  DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("explore_sessions")
}

// 寶箱：消耗 hearts → 隨機掉落
enum TreasureType {
  GOLD // 黃金寶箱 (10000 hearts)
  SILVER // 白銀寶箱 (1000 hearts)
  BRONZE // 青銅寶箱 (100 hearts)
}

model TreasureDrop {
  id       String       @id @default(cuid())
  treasure TreasureType
  itemId   String       @map("item_id")
  weight   Int          @default(1)
  minQty   Int          @default(1) @map("min_qty")
  maxQty   Int          @default(1) @map("max_qty")

  item GameItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([treasure])
  @@map("treasure_drops")
}

model TreasureSession {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  treasure   TreasureType
  heartsUsed Int          @map("hearts_used")
  rewards    Json
  createdAt  DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("treasure_sessions")
}

// 勳章合成配方：消耗多個小勳章 → 換大勳章
model MedalRecipe {
  id          String   @id @default(cuid())
  outputSlug  String   @map("output_slug") // 對應 Medal.slug
  outputCount Int      @default(1) @map("output_count")
  ingredients Json // [{medalSlug, quantity}]
  costCoins   Int      @default(0) @map("cost_coins")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([outputSlug])
  @@map("medal_recipes")
}

// ============================================================
// 即時留言版（Supabase Realtime broadcast）
// ============================================================

model ChatRoom {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String        @db.VarChar(80)
  description String?       @db.Text
  rating      ContentRating @default(G)
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  senderId  String   @map("sender_id")
  content   String   @db.VarChar(500)
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("chatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ============================================================
// 個人日誌（Blog）
// ============================================================

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Blog {
  id        String     @id @default(cuid())
  authorId  String     @map("author_id")
  title     String     @db.VarChar(200)
  content   String     @db.Text
  coverUrl  String?    @map("cover_url") @db.Text
  isPublic  Boolean    @default(true) @map("is_public")
  status    BlogStatus @default(PUBLISHED)
  hotScore  Float      @default(0) @map("hot_score")
  hasVideo  Boolean    @default(false) @map("has_video")
  viewCount Int        @default(0) @map("view_count")
  likeCount Int        @default(0) @map("like_count")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments BlogComment[]
  storeLink BlogStoreLink?

  @@index([authorId, createdAt])
  @@index([isPublic, createdAt])
  @@index([status, hotScore])
  @@map("blogs")
}

model BlogComment {
  id        String   @id @default(cuid())
  blogId    String   @map("blog_id")
  authorId  String   @map("author_id")
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  blog   Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([blogId, createdAt])
  @@map("blog_comments")
}

// ============================================================
// 文章評分 + 投票帖
// ============================================================

model PostRating {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  score     Int // 1-5
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("post_ratings")
}

model Poll {
  id            String    @id @default(cuid())
  postId        String    @unique @map("post_id")
  question      String    @db.VarChar(300)
  multiSelect   Boolean   @default(false) @map("multi_select")
  showResultsAt String    @default("after_vote") @map("show_results_at") // after_vote | always | after_close
  closesAt      DateTime? @map("closes_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@map("polls")
}

model PollOption {
  id        String @id @default(cuid())
  pollId    String @map("poll_id")
  label     String @db.VarChar(120)
  voteCount Int    @default(0) @map("vote_count")
  sortOrder Int    @default(0) @map("sort_order")

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String   @map("poll_id")
  optionId  String   @map("option_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

// ============================================================
// 文章置頂購買（自助廣告）
// ============================================================

enum PromotionType {
  FORUM_PIN_24H        // 版內置頂 24 小時
  FORUM_PIN_7D         // 版內置頂 7 天
  HOME_FEATURED_7D     // 首頁精華 7 天
  HOME_HERO_7D         // 首頁 hero 輪播 7 天
  CATEGORY_PIN_3D      // 大分類置頂 3 天
  HOT_TOP_24H          // 全站熱門推 24 小時
}

enum PromotionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  COINS
  ECPAY
  NEWEBPAY
  STRIPE
  ADMIN_GIFT
  TASK_REWARD
  CHECKIN_REWARD
}

model PromotionOrder {
  id          String          @id @default(cuid())
  postId      String          @map("post_id")
  userId      String          @map("user_id")
  type        PromotionType
  status      PromotionStatus @default(PENDING)
  paymentMethod PaymentMethod @map("payment_method")
  priceCoins  Int             @default(0) @map("price_coins")
  priceTwd    Int             @default(0) @map("price_twd")
  startAt     DateTime?       @map("start_at")
  endAt       DateTime?       @map("end_at")
  paidAt      DateTime?       @map("paid_at")
  paymentRef  String?         @map("payment_ref")
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([postId])
  @@index([userId, status])
  @@index([status, endAt])
  @@map("promotion_orders")
}

model PromotionVoucher {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  type        PromotionType
  source      String        @db.VarChar(50)
  usedAt      DateTime?     @map("used_at")
  usedOrderId String?       @map("used_order_id")
  expiresAt   DateTime?     @map("expires_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([userId, usedAt])
  @@map("promotion_vouchers")
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(20)
  ownerId   String   @map("owner_id")
  uses      Int      @default(0)
  maxUses   Int      @default(10) @map("max_uses")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerId])
  @@map("invite_codes")
}

model InviteUse {
  id        String   @id @default(cuid())
  codeId    String   @map("code_id")
  inviterId String   @map("inviter_id")
  inviteeId String   @unique @map("invitee_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([inviterId])
  @@map("invite_uses")
}

// ============================================================
// 下載專區
// ============================================================

enum DownloadCategory {
  WALLPAPER     // 桌布
  FONT          // 字體
  EBOOK         // 電子書
  TOOL          // 工具軟體
  AUDIO         // 音樂/音效
  VIDEO         // 影片
  IMAGE_PACK    // 圖包
  GAME          // 遊戲
  TEMPLATE      // 範本
  OTHER         // 其他
}

model DownloadResource {
  id            String           @id @default(cuid())
  title         String           @db.VarChar(200)
  description   String?          @db.Text
  category      DownloadCategory
  fileUrl       String           @db.Text @map("file_url")
  fileSize      Int              @default(0) @map("file_size") // bytes
  fileType      String?          @map("file_type") @db.VarChar(40) // pdf/zip/mp3/mp4/png
  thumbnailUrl  String?          @db.Text @map("thumbnail_url")

  // 取得方式
  costCredits   Int              @default(1) @map("cost_credits")  // 下載額度成本
  costCoins     Int              @default(0) @map("cost_coins")    // 或用金幣
  requiresVip   Boolean          @default(false) @map("requires_vip")
  minReadPower  Int              @default(0) @map("min_read_power")
  rating        ContentRating    @default(G)

  // 統計
  downloadCount Int              @default(0) @map("download_count")
  isActive      Boolean          @default(true) @map("is_active")
  isFeatured    Boolean          @default(false) @map("is_featured")

  uploaderId    String           @map("uploader_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  history DownloadHistory[]

  @@index([category, isActive])
  @@index([isFeatured, isActive])
  @@index([downloadCount])
  @@map("download_resources")
}

// 用戶持有的下載額度
model DownloadCredit {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  balance   Int      @default(0)
  totalEarned Int    @default(0) @map("total_earned")
  totalSpent  Int    @default(0) @map("total_spent")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("download_credits")
}

// 下載歷史 / 額度交易記錄
enum CreditChangeReason {
  EARN_TASK         // 任務獎勵
  EARN_CHECKIN      // 簽到獎勵
  EARN_VIP_MONTHLY  // VIP 月配
  EARN_PURCHASE     // 金幣換 credits
  EARN_ADMIN_GIFT   // 管理員贈送
  EARN_REFERRAL     // 推廣拉新
  SPEND_DOWNLOAD    // 下載資源
  SPEND_ADMIN_DEDUCT // 管理員扣除
}

model DownloadCreditLedger {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  delta     Int                 // +earn / -spend
  balance   Int                 // 操作後餘額
  reason    CreditChangeReason
  relatedId String?             @map("related_id")
  note      String?
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("download_credit_ledger")
}

model DownloadHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  resourceId  String   @map("resource_id")
  paidCredits Int      @default(0) @map("paid_credits")
  paidCoins   Int      @default(0) @map("paid_coins")
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  resource DownloadResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, downloadedAt])
  @@index([resourceId])
  @@map("download_history")
}

// ============================================================
// PRD-0503: 業者廣告刊登系統
// ============================================================

enum UserType {
  MEMBER       // 一般會員（預設）
  BUSINESS     // 業者 / 廣告主
}

enum BusinessAdStatus {
  DRAFT        // 草稿
  PENDING      // 待審
  ACTIVE       // 上架中
  REJECTED     // 退回
  EXPIRED      // 已過期 (30 天)
  TAKEN_DOWN   // 業者主動下架
  REMOVED      // 管理員下架
}

enum AdTier {
  FREE         // 免費
  T500         // NT$500
  T1000        // NT$1000
  T2000        // NT$2000
  T3000        // NT$3000
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// 業者廣告 listing — 跟既有 Advertisement (banner) 不同
model BusinessAd {
  id              String           @id @default(cuid())
  merchantId      String           @map("merchant_id")
  forumId         String           @map("forum_id")    // 刊登在哪個版區
  title           String           @db.VarChar(150)
  description     String           @db.Text
  // 地區 (兩層: 縣市 → 區)
  city            String           @db.VarChar(20)    // 例：台北市
  district        String           @db.VarChar(20)    // 例：信義區
  // 標籤 (JSON array of strings: ["室內", "冷氣", "停車"])
  tags            Json             @default("[]")
  // 9:16 卡片用：主圖 + 多圖
  coverImageUrl   String?          @db.Text @map("cover_image_url")
  imageUrls       Json             @default("[]") @map("image_urls")
  // 價格區間
  priceMin        Int?             @map("price_min")  // NT$
  priceMax        Int?             @map("price_max")
  // 評分 (跟 Post.ratingAvg 不同 system，由消費者日誌彙總)
  ratingAvg       Float            @default(0) @map("rating_avg")
  ratingCount     Int              @default(0) @map("rating_count")
  // 付費等級 + 排序
  tier            AdTier           @default(FREE)
  tierAmountTwd   Int              @default(0) @map("tier_amount_twd")  // 實際扣款額
  // 狀態 + 時間
  status          BusinessAdStatus @default(DRAFT)
  publishedAt     DateTime?        @map("published_at")
  expiresAt       DateTime?        @map("expires_at")  // published_at + 30 days
  rejectReason    String?          @map("reject_reason")
  // 統計
  viewCount       Int              @default(0) @map("view_count")
  clickCount      Int              @default(0) @map("click_count")
  favoriteCount   Int              @default(0) @map("favorite_count")
  contactCount    Int              @default(0) @map("contact_count")
  // 排序權重 (tier 高 + 較新 = 高)
  sortWeight      Float            @default(0) @map("sort_weight")
  // 排程發布（V1.1）
  scheduledAt     DateTime?        @map("scheduled_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  blogLinks       BlogStoreLink[]
  comments        BusinessAdComment[]

  @@index([forumId, status, sortWeight])
  @@index([merchantId, status])
  @@index([city, district, status])
  @@index([status, expiresAt])
  @@map("business_ads")
}

// 業者錢包 (跟既有 UserPoints 不同；這是真錢 TWD)
model BusinessWallet {
  id            String   @id @default(cuid())
  merchantId    String   @unique @map("merchant_id")
  balance       Int      @default(0)         // 可用餘額 NT$
  totalDeposit  Int      @default(0) @map("total_deposit")   // 累計儲值
  totalSpent    Int      @default(0) @map("total_spent")     // 累計扣款
  totalWithdraw Int      @default(0) @map("total_withdraw")  // 累計提現
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("business_wallets")
}

enum WalletTxType {
  DEPOSIT       // 儲值
  AD_PAYMENT    // 廣告扣款
  REFUND        // 退款
  WITHDRAWAL    // 提現
  ADMIN_ADJUST  // 管理員調整
}

model BusinessWalletTx {
  id          String       @id @default(cuid())
  merchantId  String       @map("merchant_id")
  type        WalletTxType
  amount      Int          // 正數=入；負數=出
  balance     Int          // 操作後餘額
  relatedId   String?      @map("related_id")  // adId / withdrawalId / orderId
  note        String?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([merchantId, createdAt])
  @@map("business_wallet_tx")
}

// 提現申請
model WithdrawalRequest {
  id              String           @id @default(cuid())
  merchantId      String           @map("merchant_id")
  amount          Int              // NT$
  bankCode        String           @map("bank_code") @db.VarChar(10)
  bankAccount     String           @map("bank_account") @db.VarChar(30)
  bankAccountName String           @map("bank_account_name") @db.VarChar(50)
  status          WithdrawalStatus @default(PENDING)
  rejectReason    String?          @map("reject_reason")
  reviewedBy      String?          @map("reviewed_by")
  reviewedAt      DateTime?        @map("reviewed_at")
  paidAt          DateTime?        @map("paid_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([merchantId, status])
  @@index([status, createdAt])
  @@map("withdrawal_requests")
}

// 地區資料表 (台灣縣市/區)
model Region {
  id        Int     @id @default(autoincrement())
  city      String  @db.VarChar(20)
  district  String  @db.VarChar(20)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@unique([city, district])
  @@index([city, sortOrder])
  @@map("regions")
}

// 日誌綁定店家連結（PRD: 強制綁定）
model BlogStoreLink {
  id        String   @id @default(cuid())
  blogId    String   @unique @map("blog_id")
  adId      String   @map("ad_id")
  createdAt DateTime @default(now()) @map("created_at")

  blog  Blog       @relation(fields: [blogId], references: [id], onDelete: Cascade)
  bizAd BusinessAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("blog_store_links")
}

// V1.1：業者廣告留言
model BusinessAdComment {
  id        String   @id @default(cuid())
  adId      String   @map("ad_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  parentId  String?  @map("parent_id")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ad BusinessAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, createdAt])
  @@map("business_ad_comments")
}

// V1.1：違禁詞庫
model BannedWord {
  id        Int      @id @default(autoincrement())
  word      String   @unique @db.VarChar(50)
  severity  String   @default("BLOCK") @db.VarChar(10) // BLOCK / FLAG
  category  String?  @db.VarChar(30)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([severity])
  @@map("banned_words")
}

// V1.1：搜尋日誌
model SearchLog {
  id        BigInt   @id @default(autoincrement())
  query     String   @db.VarChar(120)
  userId    String?  @map("user_id")
  scope     String   @default("listing") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([query])
  @@index([createdAt])
  @@map("search_logs")
}

// V1.1：折扣碼
enum CouponType {
  PERCENT // 百分比折扣（value=10 表 10%）
  FIXED   // 固定金額折扣（value=100 表 -100）
  BONUS   // 加碼贈點（value=200 表 儲值 N + 200）
}

model CouponCode {
  id          String     @id @default(cuid())
  code        String     @unique @db.VarChar(20)
  type        CouponType
  value       Int
  minAmount   Int        @default(0) @map("min_amount")
  maxUses     Int?       @map("max_uses")
  usedCount   Int        @default(0) @map("used_count")
  expiresAt   DateTime?  @map("expires_at")
  isActive    Boolean    @default(true) @map("is_active")
  description String?    @db.Text
  createdBy   String?    @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("coupon_codes")
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String   @map("coupon_id")
  userId    String   @map("user_id")
  amount    Int
  bonus     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([couponId, userId])
  @@index([userId])
  @@map("coupon_redemptions")
}

// V1.1：用戶行為日誌
model UserActivity {
  id         BigInt   @id @default(autoincrement())
  userId     String   @map("user_id")
  action     String   @db.VarChar(40)
  targetType String?  @map("target_type") @db.VarChar(30)
  targetId   String?  @map("target_id")
  metadata   Json?
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("user_activities")
}

// 收藏業者廣告
model BusinessAdFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  adId      String   @map("ad_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, adId])
  @@index([userId, createdAt])
  @@map("business_ad_favorites")
}
