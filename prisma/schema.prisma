// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 列舉型別 (Enums)
// ============================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  MUTED
  BANNED
  SUSPENDED
  DELETED
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
  LOCKED
}

enum PostVisibility {
  PUBLIC
  REPLY_TO_VIEW
  PAID
  VIP_ONLY
  PRIVATE
}

enum ReplyStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum ReportType {
  PORNOGRAPHY
  VIOLENCE
  SPAM
  HARASSMENT
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  POST
  REPLY
  USER
}

enum NotificationType {
  REPLY
  LIKE
  FOLLOW
  MENTION
  SYSTEM
  REPORT_RESULT
  LEVEL_UP
  ACHIEVEMENT
}

enum PointType {
  REPUTATION
  COINS
  PLATINUM
}

enum PointChangeReason {
  POST_CREATED
  POST_LIKED
  REPLY_CREATED
  REPLY_LIKED
  DAILY_CHECKIN
  CHECKIN_STREAK
  ACHIEVEMENT_UNLOCK
  ADMIN_ADJUST
  VIP_BONUS
  PENALTY
}

enum AdminActionType {
  USER_BAN
  USER_UNBAN
  USER_MUTE
  USER_UNMUTE
  POST_DELETE
  POST_HIDE
  POST_PIN
  POST_UNPIN
  POST_FEATURE
  POST_LOCK
  POST_MOVE
  REPLY_DELETE
  FORUM_CREATE
  FORUM_EDIT
  FORUM_DELETE
  REPORT_RESOLVE
  REPORT_DISMISS
  POINTS_ADJUST
  LEVEL_ADJUST
  SETTINGS_CHANGE
}

// ============================================================
// NextAuth.js 必需模型
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// 用戶系統
// ============================================================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  emailVerified  DateTime?
  hashedPassword String?
  username       String     @unique @db.VarChar(30)
  displayName    String     @db.VarChar(50)
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?
  lastLoginIp    String?    @db.VarChar(45)

  // 關聯
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  points        UserPoints?

  // 內容
  posts         Post[]
  replies       Reply[]

  // 互動
  likes         Like[]
  favorites     Favorite[]
  reports       Report[]        @relation("reporter")

  // 通知
  notifications Notification[]  @relation("recipient")

  // 用戶關係
  following     UserFollow[]    @relation("follower")
  followers     UserFollow[]    @relation("following")
  blocking      UserBlock[]     @relation("blocker")
  blockedBy     UserBlock[]     @relation("blocked")

  // 簽到
  checkins      Checkin[]

  // 版主
  moderating    ForumModerator[]

  // 管理日誌
  adminLogs     AdminLog[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  avatarUrl   String?  @db.Text
  signature   String?  @db.VarChar(200)
  bio         String?  @db.VarChar(500)
  website     String?  @db.VarChar(255)
  location    String?  @db.VarChar(100)
  birthday    DateTime?
  gender      String?  @db.VarChar(10)
  isPublic    Boolean  @default(true)

  // 統計快取
  postCount      Int @default(0)
  replyCount     Int @default(0)
  likeCount      Int @default(0)
  followerCount  Int @default(0)
  followingCount Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserPoints {
  id         String @id @default(cuid())
  userId     String @unique

  reputation Int @default(0)
  coins      Int @default(0)
  platinum   Int @default(0)

  totalPoints Int @default(0)
  level       Int @default(16)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model PointHistory {
  id        String            @id @default(cuid())
  userId    String
  type      PointType
  amount    Int
  reason    PointChangeReason
  detail    String?           @db.VarChar(200)
  relatedId String?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("point_histories")
}

// ============================================================
// 用戶關係
// ============================================================

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ============================================================
// 看板系統（三層架構）
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  iconUrl     String?  @db.Text
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forums Forum[]

  @@index([slug])
  @@index([sortOrder])
  @@map("categories")
}

model Forum {
  id             String   @id @default(cuid())
  categoryId     String
  name           String   @db.VarChar(100)
  slug           String   @unique @db.VarChar(100)
  description    String?  @db.Text
  iconUrl        String?  @db.Text
  bannerUrl      String?  @db.Text
  rules          String?  @db.Text
  sortOrder      Int      @default(0)
  isVisible      Boolean  @default(true)
  isLocked       Boolean  @default(false)
  minLevelToPost Int      @default(16)
  minLevelToView Int      @default(16)

  // 統計快取
  postCount      Int      @default(0)
  todayPostCount Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subforums  Subforum[]
  posts      Post[]
  moderators ForumModerator[]

  @@index([categoryId])
  @@index([slug])
  @@index([sortOrder])
  @@map("forums")
}

model Subforum {
  id          String   @id @default(cuid())
  forumId     String
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  forum Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  posts Post[]

  @@unique([forumId, slug])
  @@index([forumId])
  @@map("subforums")
}

model ForumModerator {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  createdAt DateTime @default(now())

  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
  @@map("forum_moderators")
}

// ============================================================
// 文章與回覆系統
// ============================================================

model Post {
  id             String         @id @default(cuid())
  authorId       String
  forumId        String
  subforumId     String?
  title          String         @db.VarChar(200)
  content        String         @db.Text
  excerpt        String?        @db.VarChar(300)
  slug           String         @unique @db.VarChar(250)
  status         PostStatus     @default(PUBLISHED)
  visibility     PostVisibility @default(PUBLIC)
  paidCoins      Int            @default(0)

  // 置頂與精華
  isPinned       Boolean        @default(false)
  pinnedAt       DateTime?
  isFeatured     Boolean        @default(false)
  featuredAt     DateTime?
  isHighlighted  Boolean        @default(false)
  highlightColor String?        @db.VarChar(7)

  // 統計快取
  viewCount      Int            @default(0)
  likeCount      Int            @default(0)
  dislikeCount   Int            @default(0)
  replyCount     Int            @default(0)
  favoriteCount  Int            @default(0)

  // 最後活動
  lastReplyAt    DateTime?
  lastReplyById  String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // 關聯
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum       Forum           @relation(fields: [forumId], references: [id], onDelete: Cascade)
  subforum    Subforum?       @relation(fields: [subforumId], references: [id], onDelete: SetNull)
  replies     Reply[]
  attachments PostAttachment[]
  likes       Like[]
  favorites   Favorite[]
  reports     Report[]
  tags        PostTag[]

  @@index([authorId])
  @@index([forumId, status, createdAt])
  @@index([forumId, isPinned, lastReplyAt])
  @@index([forumId, subforumId, status])
  @@index([status, createdAt])
  @@index([slug])
  @@index([likeCount])
  @@index([viewCount])
  @@map("posts")
}

model Reply {
  id           String      @id @default(cuid())
  postId       String
  authorId     String
  parentId     String?
  content      String      @db.Text
  status       ReplyStatus @default(PUBLISHED)
  floor        Int

  // 統計
  likeCount    Int         @default(0)
  dislikeCount Int         @default(0)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // 關聯
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Reply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: SetNull)
  children Reply[] @relation("ReplyToReply")
  likes    Like[]

  @@index([postId, floor])
  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("replies")
}

model PostAttachment {
  id         String   @id @default(cuid())
  postId     String
  fileName   String   @db.VarChar(255)
  fileUrl    String   @db.Text
  fileSize   Int
  mimeType   String   @db.VarChar(100)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

// ============================================================
// 互動系統
// ============================================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  replyId   String?
  isLike    Boolean  @default(true)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post  Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply Reply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([postId])
  @@index([replyId])
  @@map("likes")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@map("favorites")
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  type        ReportType
  reason      String           @db.Text
  evidence    String?          @db.Text
  status      ReportStatus     @default(PENDING)
  resolution  String?          @db.Text
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reporter User  @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@map("reports")
}

// ============================================================
// 標籤系統
// ============================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String?  @db.VarChar(7)
  postCount Int      @default(0)
  createdAt DateTime @default(now())

  posts PostTag[]

  @@index([slug])
  @@index([postCount])
  @@map("tags")
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

// ============================================================
// 通知系統
// ============================================================

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String           @db.VarChar(200)
  content     String?          @db.VarChar(500)
  linkUrl     String?          @db.Text
  isRead      Boolean          @default(false)
  senderId    String?
  relatedId   String?
  createdAt   DateTime         @default(now())

  recipient User @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ============================================================
// 簽到系統
// ============================================================

model Checkin {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  streak      Int      @default(1)
  coinsEarned Int      @default(30)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("checkins")
}

// ============================================================
// 管理日誌
// ============================================================

model AdminLog {
  id         String          @id @default(cuid())
  adminId    String
  action     AdminActionType
  targetType String          @db.VarChar(50)
  targetId   String
  detail     String?         @db.Text
  ipAddress  String?         @db.VarChar(45)
  createdAt  DateTime        @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@map("admin_logs")
}
